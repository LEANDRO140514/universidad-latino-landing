{
  "instrument": {
    "test_id": "UL_TEST_VOCACIONAL",
    "version": "1.2.0",
    "name": "Test Vocacional Universidad Latino",
    "description": "Instrumento psicométrico de orientación vocacional basado en el modelo Holland modificado (RIASEC → SINP) con capas de aptitudes, valores de vida y motivación.",
    "total_items": 17,
    "estimated_duration_minutes": 5,
    "language": "es-MX"
  },
  "voice": {
    "persona": "Eva, asistente de orientación vocacional de la Universidad Latino",
    "tone": "cálido, conciso, profesional",
    "register": "tú (informal)",
    "rules": [
      "Mantener respuestas breves (máx. 3 líneas por turno cuando sea posible).",
      "Validar cada respuesta antes de avanzar.",
      "No revelar puntajes ni fórmulas internas.",
      "Evitar repetir frases de bienvenida una vez iniciado el test.",
      "use_examples: Utilizar ejemplos claros cuando sea necesario para explicar opciones.",
      "do_not_overpromise_becas: Al mencionar becas, usar lenguaje tentativo (posibles, potenciales, según perfil). Nunca garantizar porcentajes exactos."
    ]
  },
  "flow": {
    "phases": [
      {
        "id": "P0_INTRO",
        "name": "Bienvenida",
        "steps": [
          "greeting",
          "explain_test",
          "ask_consent"
        ]
      },
      {
        "id": "P1_DATOS",
        "name": "Captura de nombre",
        "fields": [
          "nombre"
        ]
      },
      {
        "id": "P2_CORE",
        "name": "Bloque Likert (13 ítems)",
        "items": "Q01–Q13"
      },
      {
        "id": "P3_CONTEXTO",
        "name": "Contexto y metas (urgencia, promedio)",
        "items": "urgencia, promedio"
      },
      {
        "id": "P4_CONTACTO",
        "name": "Captura de contacto",
        "fields": [
          "telefono",
          "email"
        ]
      },
      {
        "id": "P5_RESULTADO",
        "name": "Procesamiento y dictamen"
      }
    ]
  },
  "items": {
    "likert_core": [
      {
        "id": "Q01",
        "prompt": "Me interesa comprender el bienestar físico y participar en acciones que favorezcan hábitos de cuidado y salud.",
        "dimension": "I_SALUD"
      },
      {
        "id": "Q02",
        "prompt": "Me atrae acompañar u orientar a otras personas en decisiones o situaciones personales.",
        "dimension": "I_SOCIAL"
      },
      {
        "id": "Q03",
        "prompt": "Me motiva coordinar, mejorar procesos y lograr objetivos dentro de un equipo u organización.",
        "dimension": "I_NEGOCIOS"
      },
      {
        "id": "Q04",
        "prompt": "Me llama la atención la tecnología y la posibilidad de crear o mejorar soluciones digitales.",
        "dimension": "I_TECNOLOGIA"
      },
      {
        "id": "Q05",
        "prompt": "Se me facilita analizar un problema y estructurar una solución paso a paso.",
        "dimension": "A_ANALITICO"
      },
      {
        "id": "Q06",
        "prompt": "Suelo captar con facilidad lo que otra persona necesita y responder con sensibilidad y criterio.",
        "dimension": "A_EMPATICO"
      },
      {
        "id": "Q07",
        "prompt": "Aprendo mejor cuando puedo aplicar lo aprendido en prácticas, casos o situaciones reales.",
        "dimension": "A_PRACTICO"
      },
      {
        "id": "Q08",
        "prompt": "Puedo organizarme y avanzar con constancia sin depender de supervisión continua.",
        "dimension": "A_AUTOGESTION"
      },
      {
        "id": "Q09",
        "prompt": "Actualmente tengo responsabilidades (trabajo, familia u otras) que limitan mi disponibilidad entre semana.",
        "dimension": "V_RESPONSABILIDADES"
      },
      {
        "id": "Q10",
        "prompt": "Me adapto bien a estudiar desde casa y sostener avances con actividades en línea.",
        "dimension": "V_REMOTO"
      },
      {
        "id": "Q11",
        "prompt": "Cuento con disponibilidad real para concentrar estudio en fin de semana (especialmente sábados).",
        "dimension": "V_FINDE"
      },
      {
        "id": "Q12",
        "prompt": "En este momento, iniciar la universidad es una meta concreta y prioritaria para mí.",
        "dimension": "M_CLARIDAD_META"
      },
      {
        "id": "Q13",
        "prompt": "Estoy dispuesto(a) a sostener el esfuerzo académico incluso cuando haya semanas exigentes.",
        "dimension": "M_COMPROMISO"
      }
    ],
    "context_questions": [
      {
        "id": "urgencia",
        "prompt": "¿Cuándo te gustaría iniciar tu carrera universitaria?",
        "type": "single_choice",
        "options": [
          {
            "value": "ASAP",
            "label": "Lo antes posible"
          },
          {
            "value": "ESTE_ANIO",
            "label": "Este año"
          },
          {
            "value": "6_12",
            "label": "En los próximos 6 a 12 meses"
          },
          {
            "value": "EXPLORANDO",
            "label": "Solo estoy explorando por ahora"
          }
        ],
        "dimension": "C_URGENCIA"
      },
      {
        "id": "promedio",
        "prompt": "¿Cuál fue tu promedio aproximado (o nivel de desempeño) en tu último grado?",
        "type": "single_choice",
        "options": [
          {
            "value": "EXCELENTE",
            "label": "Excelente (≈ 9.5 o más)"
          },
          {
            "value": "MUY_BUENO",
            "label": "Muy bueno (≈ 9.0 a 9.4)"
          },
          {
            "value": "BUENO",
            "label": "Bueno (≈ 8.5 a 8.9)"
          },
          {
            "value": "REGULAR",
            "label": "Regular (≈ 8.0 a 8.4)"
          },
          {
            "value": "NO_DIGO",
            "label": "Prefiero no decirlo"
          }
        ],
        "dimension": "C_PROMEDIO"
      }
    ]
  },
  "dimensions": {
    "interests": {
      "I_SALUD": "Interés en salud y bienestar",
      "I_SOCIAL": "Interés en acompañamiento/orientación",
      "I_NEGOCIOS": "Interés en gestión y negocios",
      "I_TECNOLOGIA": "Interés en tecnología"
    },
    "aptitudes": {
      "A_ANALITICO": "Pensamiento analítico",
      "A_EMPATICO": "Sensibilidad interpersonal",
      "A_PRACTICO": "Aprendizaje aplicado",
      "A_AUTOGESTION": "Autonomía y constancia"
    },
    "life_values": {
      "V_RESPONSABILIDADES": "Carga de responsabilidades",
      "V_REMOTO": "Adaptación a estudio remoto",
      "V_FINDE": "Disponibilidad fin de semana"
    },
    "motivation": {
      "M_CLARIDAD_META": "Claridad de meta universitaria",
      "M_COMPROMISO": "Compromiso con esfuerzo académico"
    },
    "context": {
      "C_URGENCIA": "Urgencia de inicio",
      "C_PROMEDIO": "Desempeño académico previo"
    }
  },
  "scoring": {
    "likert_scale": {
      "min": 1,
      "max": 5,
      "labels": {
        "1": "Nada",
        "2": "Poco",
        "3": "Moderado",
        "4": "Mucho",
        "5": "Totalmente"
      }
    },
    "sector_formulas": {
      "SALUD": "I_SALUD × 1.0 + A_PRACTICO × 0.30 + A_EMPATICO × 0.20 + I_SOCIAL × 0.30",
      "NEGOCIOS": "I_NEGOCIOS × 1.0 + A_ANALITICO × 0.30 + A_AUTOGESTION × 0.15",
      "TECNOLOGIA": "I_TECNOLOGIA × 1.0 + A_ANALITICO × 0.55",
      "DERECHO": "A_ANALITICO × 0.55 + M_CLARIDAD_META × 0.25 + I_NEGOCIOS × 0.20"
    },
    "cohesion_gates": {
      "SALUD": {
        "must_all": [
          {
            "dim": "I_SALUD",
            ">=": 3
          }
        ],
        "must_any": [
          {
            "dim": "A_PRACTICO",
            ">=": 3
          },
          {
            "dim": "A_EMPATICO",
            ">=": 3
          }
        ]
      },
      "NEGOCIOS": {
        "must_all": [
          {
            "dim": "I_NEGOCIOS",
            ">=": 3
          }
        ],
        "must_any": [
          {
            "dim": "A_ANALITICO",
            ">=": 3
          },
          {
            "dim": "A_AUTOGESTION",
            ">=": 3
          }
        ]
      },
      "TECNOLOGIA": {
        "must_all": [
          {
            "dim": "I_TECNOLOGIA",
            ">=": 3
          },
          {
            "dim": "A_ANALITICO",
            ">=": 3
          }
        ]
      },
      "DERECHO": {
        "must_any": [
          {
            "dim": "A_ANALITICO",
            ">=": 3
          },
          {
            "dim": "M_CLARIDAD_META",
            ">=": 3
          }
        ]
      }
    },
    "mixed_profile_threshold": 0.8
  },
  "career_mappings": {
