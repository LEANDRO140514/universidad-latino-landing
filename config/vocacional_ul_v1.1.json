    "constraints": {
      "max_recommendations": 3,
      "mixed_profile_distribution": "2 del sector primario + 1 del secundario"
    }
  },
  "modality_rules": {
    "SABATINA": {
      "conditions": [
        {
          "dim": "V_FINDE",
          ">=": 4
        },
        {
          "dim": "V_RESPONSABILIDADES",
          ">=": 3
        }
      ]
    },
    "ONLINE": {
      "conditions": [
        {
          "dim": "V_REMOTO",
          ">=": 4
        },
        {
          "dim": "A_AUTOGESTION",
          ">=": 4
        }
      ]
    },
    "fallback": "PRESENCIAL"
  },
  "lead_scoring": {
    "formula": "vocational_compat × 0.45 + persistence × 0.22 + urgency × 0.20 + performance × 0.08 + ai_relation × 0.05",
    "components": {
      "vocational_compat": "normalize(top_program_score, 1, 5)",
      "persistence": "avg(A_AUTOGESTION, M_COMPROMISO, M_CLARIDAD_META)",
      "urgency": "C_URGENCIA mapped",
      "performance": "C_PROMEDIO mapped",
      "ai_relation": "fixed at 3 (neutral)"
    },
    "thresholds": {
      "HOT": "≥ 85",
      "WARM": "65–84",
      "COLD": "< 65"
    }
  },
  "scholarships_and_supports": {
    "mapping": {
      "EXCELENTE": {
        "band": "EXCELENCIA",
        "range": "40-50%",
        "eva_message": "Por tu excelente desempeño, podrías acceder a una beca de excelencia académica que cubre entre 40% y 50% de tu colegiatura."
      },
      "MUY_BUENO": {
        "band": "MÉRITO ALTO",
        "range": "30-40%",
        "eva_message": "Tu buen promedio te posiciona para una beca de mérito alto, con posible apoyo entre 30% y 40%."
      },
      "BUENO": {
        "band": "MÉRITO MEDIO",
        "range": "20-30%",
        "eva_message": "Existen becas de mérito medio disponibles para tu perfil, que podrían cubrir entre 20% y 30%."
      },
      "REGULAR": {
        "band": "BÁSICA",
        "range": "15-20%",
        "eva_message": "Hay opciones de beca básica disponibles que podrían apoyarte con 15% a 20% de tu colegiatura."
      },
      "NO_DIGO": {
        "band": "BÁSICA",
        "range": "15-20%",
        "eva_message": "Sin importar tu promedio, existen opciones de apoyo económico. Un asesor puede orientarte sobre las becas disponibles."
      }
    }
  },
  "result_delivery": {
    "dictamen_style": "Técnico-orientador: objetiva las fortalezas del candidato y justifica la recomendación con base en el perfil, sin exageraciones ni promesas.",
    "templates": {
      "single_sector": "{nombre}, con base en tus respuestas, se observa una afinidad predominante hacia el área de {sector_name}. Tu perfil combina {strength_1} y {strength_2}, lo que favorece un desempeño consistente en procesos formativos con {learning_style}. Recomendación principal: {top_program} en modalidad {mode} y periodo {period}. Como rutas complementarias, también aparecen {alt_1} y {alt_2}.",
      "mixed_sector": "{nombre}, tus respuestas reflejan un perfil con dos ejes de interés relevantes: {sector_primary_name} como tendencia principal y {sector_secondary_name} como área complementaria. Esto suele presentarse cuando una persona combina {strength_1} con {strength_2}. Recomendación principal: {top_program} en modalidad {mode} y periodo {period}. Alternativas con sentido: {alt_1} (por habilidades transferibles) y {alt_2} (por alineación con el eje complementario)."
    },
    "cta_by_class": {
      "HOT": "Hablar con un asesor ahora",
      "WARM": "Ver plan de estudios",
      "COLD": "Explorar carreras"
    },
    "channels": [
      "web_page",
      "whatsapp_message",
      "crm_webhook"
    ]
  },
  "typebot_variables": {
    "input": {
      "nombre": "string",
      "telefono": "string (E.164)",
      "email": "string",
      "Q01_to_Q13": "likert_1_5",
      "urgencia": "enum",
      "promedio": "enum"
    },
    "output": {
      "sector_primary": "string",
      "sector_secondary": "string | null",
      "is_mixed": "boolean",
      "top_programs": "array[3]",
      "lead_score": "integer 0-100",
      "lead_class": "HOT | WARM | COLD",
      "dictamen_text": "string",
      "beca_elegible": "string",
      "cta_primary": "string",
      "result_url": "string"
    }
  }
